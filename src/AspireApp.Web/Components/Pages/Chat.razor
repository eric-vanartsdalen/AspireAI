@page "/chat"
@rendermode InteractiveServer
@attribute [StreamRendering]
@inject IConfiguration Configuration

@using AspireApp.Web.Components.Shared

<PageTitle>AI Chatbot</PageTitle>

<link href="~/css/speech.css" rel="stylesheet" />

<style>
	:root {
		--main-bg-color: #2C1050;
		--main-text-color: #f5f5f0;
	}

	body {
		background-color: var(--main-bg-color);
		color: var(--main-text-color);
	}

	.loading-container {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
	}

	.loading-text {
		margin: 0;
	}

	.stop-button {
		background-color: #dc3545;
		color: white;
		margin-left: 8px;
	}

	.chat-container {
		max-height: 60vh;
		overflow-y: auto;
		border: 1px solid rgba(255, 255, 255, 0.2);
		border-radius: 0.375rem;
		margin-bottom: 1rem;
		background-color: var(--main-bg-color);
	}

	.table {
		color: var(--main-text-color);
		background-color: 1px solid rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.2);
		margin-bottom: 0;
	}

	.table th {
		background-color: #1a0a30;
		color: var(--main-text-color);
		border-color: #4a4a4a;
		border-width: 2px;
		font-weight: 600;
		position: sticky;
		top: 0;
		z-index: 1;
			border-bottom: 2px solid rgba(255, 255, 255, 0.3);
	}

	.table td {
		background-color: rgba(255, 255, 255, 0.03);
		color: var(--main-text-color);
		border-color: rgba(255, 255, 255, 0.1);
		border-width: 1px;
		vertical-align: top;
		padding: 12px;
	}

	.table tbody tr:hover {
		background-color: #3a1550;
	}

	.table tbody tr:hover td {
		background-color: #3a1550;
	}

	.user-column {
		width: 100px;
		min-width: 100px;
		max-width: 100px;
		font-weight: 600;
	}

	.message-column {
		word-wrap: break-word;
		word-break: break-word;
	}

	#ai-request {
		color: var(--main-text-color);
		background-color: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.2);
		width: 100%;
		margin-bottom: 1rem;
	}

	#ai-request td {
			background-color: rgba(255, 255, 255, 0.03);
		color: var(--main-text-color);
		border-color: rgba(255, 255, 255, 0.1);
		border-width: 1px;
		padding: 8px 12px;
	}

	.form-control {
		background-color: #3a1550;
		color: var(--main-text-color);
		border: 2px solid #4a4a4a;
	}

		.form-control::placeholder {
			color: rgba(255, 255, 255, 0.6);
		}

		.form-control:focus {
			background-color: #4a1560;
			color: var(--main-text-color);
			border-color: #6a6a6a;
		}

		/* Style for disabled input */
		.form-control:disabled {
			background-color: #1a0a30;
			color: rgba(245, 245, 240, 0.7);
			border-color: #4a4a4a;
			cursor: not-allowed;
		}

	/* Scroll bar styling for webkit browsers */
	.chat-container::-webkit-scrollbar {
		width: 8px;
	}

	.chat-container::-webkit-scrollbar-track {
		background: #4a4a4a;
		border-radius: 4px;
	}

	.chat-container::-webkit-scrollbar-thumb {
		background: #6a6a6a;
		border-radius: 4px;
	}

	.chat-container::-webkit-scrollbar-thumb:hover {
		background: #8a8a8a;
	}

	/* Speech button image styling */
	.speech-button img {
		width: 24px;
		height: 24px;
		object-fit: contain;
	}

	.tts-message-button img {
		width: 16px;
		height: 16px;
		object-fit: contain;
	}

	/* Speech controls layout fixes */
	.speech-controls-container {
		margin-bottom: 1rem;
		clear: both;
		position: relative;
		z-index: 5;
	}

	.input-container {
		position: relative;
		z-index: 1;
		margin-top: 0.5rem;
	}

	.speech-status {
		margin-left: 1rem;
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		font-size: 0.9rem;
		min-height: 50px;
		vertical-align: middle;
	}
</style>

<h1>AI Chatbot</h1>

@* Speech support status *@
@if (!string.IsNullOrEmpty(SpeechStatusMessage))
{
	<div class="alert alert-warning" role="alert">
		@SpeechStatusMessage
	</div>
}

@if (IsNotFirstTimeLoading && AiInfoState.EndPointAvailable)
{
	<div id="chat-messages-container" class="chat-container">
		<table id="chathistory" class="table">
			<thead>
				<tr>
					<th class="user-column">User</th>
					<th class="message-column">Messages</th>
				</tr>
			</thead>
			<tbody>
				@foreach (var message in ChatHistoryService.GetFormattedMessages(_chatHistory))
				{
					<tr>
						<td class="user-column"><span>@message.User</span></td>
						<td class="message-column">
							<span>@ConvertToMarkup(message.Message)</span>
							@if (message.User == "Assistant" && SpeechSupport?.TextToSpeech == true)
							{
								<button class="btn btn-sm btn-outline-info ms-2 tts-message-button" 
										@onclick="() => SpeakMessage(message.Message)"
										disabled="@(IsSpeaking && !IsMessageBeingSpoken(message.Message))"
										title="@(IsMessageBeingSpoken(message.Message) ? "Stop speaking" : "Read message aloud")">
									<img src="/images/@(IsMessageBeingSpoken(message.Message) ? "stop.png" : "playback.png")" 
										 alt="@(IsMessageBeingSpoken(message.Message) ? "Stop" : "Play")" />
								</button>
							}
						</td>
					</tr>
				}
			</tbody>
		</table>
	</div>

	@if (IsAIResponsing == true)
	{
		<table id="ai-request">
			<tr>
				<td class="user-column">AI in Action&nbsp;&nbsp;</td>
				<td class="message-column">
					@if (string.IsNullOrEmpty(AIResponse))
					{
						<div class="loading-container">
							<div class="spinner-border spinner-border-sm text-primary" role="status">
								<span class="visually-hidden">Loading...</span>
							</div>
							<p class="loading-text">&nbsp;Thinking...</p>
						</div>
					}
					else
					{
						@ConvertToMarkup(AIResponse)
					}
				</td>
			</tr>
		</table>
	}

	@* Speech controls - properly positioned above input *@
	@if (SpeechSupport != null && (SpeechSupport.SpeechRecognition || SpeechSupport.TextToSpeech))
	{
		<div class="speech-controls-container">
			<div class="speech-controls">
				@if (SpeechSupport.SpeechRecognition)
				{
					<button id="mic-button" 
							class="speech-button mic-button @(IsListening ? "listening" : "")"
							@onclick="ToggleMicrophone"
							disabled="@IsAIResponsing"
							title="@(IsListening ? "Stop listening" : "Start voice input")">
						<img src="/images/@(IsListening ? "stop.png" : "record.png")" alt="@(IsListening ? "Stop Recording" : "Start Recording")" />
					</button>
				}

				@if (SpeechSupport.TextToSpeech && !string.IsNullOrEmpty(AIResponse))
				{
					<button class="speech-button tts-button"
							@onclick="ToggleTextToSpeech"
							disabled="@(string.IsNullOrEmpty(AIResponse))"
							title="@(IsMessageBeingSpoken(AIResponse) ? "Stop speaking" : "Read AI response aloud")">
						<img src="/images/@(IsMessageBeingSpoken(AIResponse) ? "stop.png" : "playback.png")" alt="@(IsMessageBeingSpoken(AIResponse) ? "Stop Speaking" : "Play Audio")" />
					</button>
				}

				<div class="speech-status">
					@if (IsListening)
					{
						<span class="text-danger"><img src="/images/record.png" style="width: 16px; height: 16px;" alt="Recording" /> Listening...</span>
					}
					else if (IsSpeaking)
					{
						<span class="text-info"><img src="/images/playback.png" style="width: 16px; height: 16px;" alt="Speaking" /> Speaking...</span>
					}
					else if (!string.IsNullOrEmpty(SpeechStatusText))
					{
						<span>@SpeechStatusText</span>
					}
				</div>
			</div>
		</div>
	}

	@* Input area with speech transcript overlay *@
	<div class="input-container">
		<div class="input-group">
			@if (!string.IsNullOrEmpty(SpeechTranscript))
			{
				<div class="speech-transcript">
					<strong>Speech:</strong> @SpeechTranscript
					@if (!string.IsNullOrEmpty(InterimTranscript))
					{
						<span class="interim-text"> @InterimTranscript</span>
					}
				</div>
			}
			
			<input @bind="Question"
				   @bind:event="oninput"
				   @onkeydown="@(async (e) => { if (e.Key == "Enter" && !IsAIResponsing) { await QueryAIChat(); } })"
				   type="text"
				   class="form-control"
				   placeholder="Enter your question or use voice input"
				   disabled="@IsAIResponsing"
				   @ref="questionInput" />
		</div>
	</div>
	
	<br />
	<div class="d-flex">
		<button class="btn btn-primary"
				@onclick="QueryAIChat"
				disabled="@IsAIResponsing">
			@(IsAIResponsing ? "Processing..." : "Send Query")
		</button>
		@if (IsAIResponsing)
		{
			<button class="btn stop-button"
					@onclick="StopAIResponse"
					title="Stop response (Ctrl+C)">
				Stop Response
			</button>
		}
	</div>
	<br />
	<div><span>Elapsed time: @ElapsedTimeMessage</span></div>
	<br />
	<br />
}
else
{
	@if (IsNotFirstTimeLoading)
	{
		<p><div><span style="background-color:darkred; color:antiquewhite; padding: 1em;"><strong>Chat Endpoint AI Service URI unavailable!</strong></span></div></p>
	}
	else
	{
		<p><div><span style="background-color: darkslateblue; color:yellowgreen; padding: 1em;"><strong>Chat AI Service loading...</strong></span></div></p>
	}
}


