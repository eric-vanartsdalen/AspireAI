@page "/"
@rendermode InteractiveServer

<PageTitle>Home</PageTitle>

<h1>Hello, world!</h1>

Welcome to your new app.

<hr />
<h3>Configuration Values</h3>

<button class="btn btn-primary mb-3" @onclick="RefreshValues">Refresh Configuration Values</button>

<ul>
    <li><b>AspireOllamaUri:</b> @HomeConfigurations.AspireOllamaUri</li>
    <li><b>AspireOllamaModel:</b> @HomeConfigurations.AspireOllamaModel</li>
    <li><b>EnvAIEndpoint:</b> @HomeConfigurations.EnvAIEndpoint</li>
    <li><b>EnvAIModel:</b> @HomeConfigurations.EnvAIModel</li>
</ul>

@code {
    private void RefreshValues()
    {
        HomeConfigurations.PullConfigure();
        StateHasChanged();
    }
}


